{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": [
		"config:best-practices",
		":pinOnlyDevDependencies",
		"group:codemirror",
		"group:fortawesome",
		"group:githubArtifactActions",
		"group:pnpm",
		"group:postcss",
		"group:remark",
		"group:test",
		"group:vite"
	],
	"minimumReleaseAge": "3 days",
	"addLabels": ["dependencies"],
	"schedule": ["on Friday"],
	"packageRules": [
		{
			"groupName": "linters",
			"extends": ["packages:linters"],
			"matchPackageNames": [
				"/prettier-plugin/",
				"/oxlint/",
				"/eslint/",
				"publint",
				"knip",
				"svelte-check",
				"/biome/",
				"@rlly/pedantic"
			]
		}
	]
}
